# Production environment file (example)
# Store at: /opt/trend_signal_engine/env/prod.env
# Permissions: root:root, chmod 600

# Kill switch (start halted until you've validated end-to-end)
TRADING_HALTED=1

# Alpaca credentials (paper first; live only after approvals)
ALPACA_API_KEY=REPLACE_ME
ALPACA_SECRET_KEY=REPLACE_ME

# Optional: force a stable RUN_ID for a run (otherwise auto-generated)
# RUN_ID=2026-03-26_close

